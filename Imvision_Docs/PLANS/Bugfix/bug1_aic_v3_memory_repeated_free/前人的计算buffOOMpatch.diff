+bool PadKernel::IsSingleDmaPad() {
+  for (auto iter = this->InputNodesBegin(); iter != this->InputNodesEnd();
+       ++iter) {
+    auto dma_in = CastNoCheck<DmaInKernel>(&*iter);
+    if (dma_in == nullptr) {
+      return false;
+    }
+  }
+  for (auto iter = this->OutputNodesBegin(); iter != this->OutputNodesEnd();
+       ++iter) {
+    auto dma_out = CastNoCheck<DmaOutKernel>(&*iter);
+    if (dma_out == nullptr) {
+      return false;
+    }
+  }
+  return true;
+}
