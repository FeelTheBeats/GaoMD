 namespace aic {
 
+namespace {
+
+constexpr uint32_t kPadCTilingMemLimit = 2 * SZ_1M;
+constexpr uint32_t kPadHTilingMemLimit = 4 * SZ_1M;
+
+std::vector<uint32_t> CalcHParts(uint32_t total_h, uint32_t split_num) {
+  std::vector<uint32_t> h_parts(split_num, total_h / split_num);
+  uint32_t remain = total_h % split_num;
+  for (uint32_t i = 0; i < remain; ++i) {
+    h_parts[i] += 1;
+  }
+  return h_parts;
+}
+
+uint32_t CalcChannelTilePart(uint32_t total_c, uint32_t mem_size) {
+  uint32_t split_num = mem_size / kPadCTilingMemLimit;
+  if (mem_size % kPadCTilingMemLimit != 0) {
+    split_num += 1;
+  }
+  uint32_t c_part = (total_c / split_num) & ~0x7;
+  if (c_part == 0) {
+    c_part = C8;
+  }
+  return c_part;
+}
+
+std::vector<uint32_t> CalcChannelTileParts(uint32_t total_c,
+                                           uint32_t mem_size) {
+  std::vector<uint32_t> c_parts;
+  uint32_t c_part = CalcChannelTilePart(total_c, mem_size);
+  for (uint32_t begin_c = 0; begin_c < total_c; begin_c += c_part) {
+    c_parts.push_back(std::min(c_part, total_c - begin_c));
+  }
+  return c_parts;
+}
+
+uint32_t CalcPadTileMallocSize(const Tensor *in_tensor,
+                               const Tensor *out_tensor, uint32_t c,
+                               uint32_t in_h, uint32_t out_h) {
+  Tensor tile_in(in_tensor->name() + "_pad_tiling_probe_in");
+  Tensor tile_out(out_tensor->name() + "_pad_tiling_probe_out");
+  tile_in.Init({1, c, in_h, in_tensor->W()}, in_tensor->data_type(),
+               in_tensor->pattern(), in_tensor->acc());
+  tile_out.Init({1, c, out_h, out_tensor->W()}, out_tensor->data_type(),
+                out_tensor->pattern(), out_tensor->acc());
+  return tile_in.GetMallocSize() + tile_out.GetMallocSize();
+}
+
+uint32_t CalcMaxPadTileMallocSize(const Tensor *in_tensor,
+                                  const Tensor *out_tensor,
+                                  const std::vector<uint32_t> &c_parts) {
+  uint32_t max_size = 0;
+  for (uint32_t c_part : c_parts) {
+    max_size = std::max(
+        max_size, CalcPadTileMallocSize(in_tensor, out_tensor, c_part,
+                                        in_tensor->H(), out_tensor->H()));
+  }
+  return max_size;
+}
+
+bool IsZeroPadding(const PadAttr &attr) {
+  return attr.pad_size_h_up == 0 && attr.pad_size_h_down == 0 &&
+         attr.pad_size_w_left == 0 && attr.pad_size_w_right == 0;
+}
+
+uint32_t CalcHeightExtraOffset(const Tensor *in_tensor, uint32_t c,
+                               uint32_t start_h) {
+  if (start_h == 0) {
+    return 0;
+  }
+
+  Tensor offset_tensor(in_tensor->name() + "_pad_h_offset_probe");
+  offset_tensor.Init({1, c, start_h, in_tensor->W()},
+                     in_tensor->data_type(), in_tensor->pattern(),
+                     in_tensor->acc());
+  if (in_tensor->pattern() == Pattern::kNCHW ||
+      in_tensor->pattern() == Pattern::kNCHW_TIGHT) {
+    return offset_tensor.GetPatchSize();
+  }
+  return offset_tensor.GetMallocSize();
+}
+
