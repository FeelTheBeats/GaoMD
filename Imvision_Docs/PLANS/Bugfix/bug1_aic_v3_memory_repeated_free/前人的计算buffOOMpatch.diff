+PadKernel::PadTileInfo PadKernel::TileAndSelect(const NodeIoArgs &args) {
+  Tensor *in_tensor = Cast<Tensor>(args[0][0]);
+  Tensor *out_tensor = Cast<Tensor>(args[1][0]);
+  PadTileInfo tile_info;
+  tile_info.mem_size = out_tensor->GetMallocSize() + in_tensor->GetMallocSize();
+  tile_info.single_pad = IsSingleDmaPad();
+
+  if (tile_info.mem_size > kPadCTilingMemLimit && tile_info.single_pad) {
+    tile_info.c_parts = CalcChannelTileParts(in_tensor->C(), tile_info.mem_size);
+    if (tile_info.c_parts.size() > 1) {
+      if (attr_.pad_mode == PadAttr::PadMode::kConstantPadding &&
+          in_tensor->pattern() == Pattern::kNpuFmt &&
+          CalcMaxPadTileMallocSize(in_tensor, out_tensor, tile_info.c_parts) >
+              kPadHTilingMemLimit &&
+          in_tensor->H() > 1) {
+        tile_info.mode = PadTileMode::kOutChannelHeightTile;
+        return tile_info;
+      }
+      tile_info.mode = PadTileMode::kOutChannelTile;
+      return tile_info;
+    }
+
+    if (attr_.pad_mode == PadAttr::PadMode::kConstantPadding &&
+        in_tensor->pattern() == Pattern::kNpuFmt && in_tensor->H() > 1) {
+      tile_info.mode = PadTileMode::kOutChannelHeightTile;
+      return tile_info;
+    }
+
+    tile_info.mode = PadTileMode::kHeightTile;
+    return tile_info;
+  }
+
+  tile_info.mode = PadTileMode::kNone;
+  return tile_info;
+}
